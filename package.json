{
  "name": "nexid",
  "version": "1.2.6",
  "author": "Thomas LE JEUNE <thomastheyoung@gmail.com>",
  "license": "MIT",
  "description": "Fast, time-sortable unique identifiers for the JavaScript ecosystem. Port of the original Go library github/rs/xid.",
  "files": [
    "bin",
    "dist",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "nexid": "bin/nexid.js"
  },
  "module": "./dist/index.mjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "imports": {
    "#common/*": "./dist/common/*.js",
    "#core/*": "./dist/core/*.js",
    "#env/*": "./dist/env/*.js",
    "#types/*": "./dist/types/*.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.mjs",
      "require": "./dist/node.js"
    },
    "./deno": {
      "types": "./dist/deno.d.ts",
      "import": "./dist/deno.mjs",
      "require": "./dist/deno.js"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "import": "./dist/web.mjs",
      "require": "./dist/web.js"
    }
  },
  "scripts": {
    "preversion": "npm test",
    "postversion": "npm publish",
    "prepublishOnly": "git push origin --follow-tags",
    "build": "rm -rf dist/ && tsup src/index.ts src/node.ts src/web.ts src/deno.ts --format cjs,esm --dts --out-dir dist",
    "bundle": "rm -rf bin/ && node esbuild.mjs",
    "benchmark": "node tests/benchmark.js",
    "test": "vitest"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@paralleldrive/cuid2": "^3.3.0",
    "@types/deno": "^2.5.0",
    "@types/node": "^25.3.3",
    "esbuild": "0.27.3",
    "hyperid": "^3.3.0",
    "ksuid": "^3.0.0",
    "nanoid": "^5.1.6",
    "prettier": "^3.8.1",
    "tinybench": "^6.0.0",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "ulid": "^3.0.2",
    "uuid": "^13.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": "20 || >=22"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thomastheyoung/nexid.git"
  },
  "bugs": {
    "url": "https://github.com/thomastheyoung/nexid/issues"
  },
  "homepage": "https://github.com/thomastheyoung/nexid#readme",
  "keywords": [
    "id",
    "guid",
    "uuid",
    "nexid",
    "identifier",
    "unique",
    "typescript",
    "globally",
    "sortable",
    "k-ordered",
    "bson"
  ]
}
